import sqlite3 
 
conn = sqlite3.connect("database.db") 
c = conn.cursor() 
 
c.execute("INSERT INTO stock VALUES (NULL,'JK Super',450,300)") 
c.execute("INSERT INTO stock VALUES (NULL,'Nagarjuna',40,380)") 
 
c.execute("INSERT INTO sales VALUES (NULL,'JK Super',356,300,'2026-04-14')") 
c.execute("INSERT INTO sales VALUES (NULL,'Nagarjuna',20,380,'2026-04-14')") 
 
conn.commit() 
conn.close() 